PORT=3001
DATABASE_PATH=./data/kanban.db
ENCRYPTION_KEY=change-me-to-a-random-32-char-string

# AI Provider: claude-cli (default), codex, anthropic, or openai
# claude-cli — uses Claude Agent SDK with your Claude subscription (no API key needed)
# codex — uses OpenAI Codex SDK with ChatGPT Enterprise SSO (no API key needed, run `codex login`)
# anthropic / openai — direct API calls (requires AI_API_KEY)
AI_PROVIDER=claude-cli
AI_MAX_TURNS=25
# AI_MODEL=                   # Optional model override
# AI_API_KEY=                  # Required for anthropic/openai providers
# AI_BASE_URL=                 # Optional custom API endpoint
